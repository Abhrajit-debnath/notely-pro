generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) 
  email     String   @unique
  name      String?
  image     String?
  password  String? 
  provider  String?
  providerId String?
  passwordConfirmation String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
